# ─────────────────────────────────────────────────────────────────────────────
# GradeAI Pro — Environment Configuration
#
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your API keys below.
# 3. NEVER commit .env — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ── AI Provider Keys (add the ones you plan to use) ──────────────────────────

# OpenAI  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini  →  https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Anthropic Claude  →  https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...


# ── Embedding Provider for RAG (choose one) ───────────────────────────────────
#
#   google   → uses gemini-embedding-001 (best quality, needs GEMINI_API_KEY)
#   openai   → uses text-embedding-3-small (good quality, needs OPENAI_API_KEY)
#   <empty>  → local all-MiniLM-L6-v2 via sentence-transformers (no API cost)
#
# Leave blank to use free local embeddings — works with no API key at all.
# If you set a provider but the key is missing, the app falls back to local automatically.
#
CHROMA_EMBEDDING_PROVIDER=


# ── Optional: override default AI models ─────────────────────────────────────
# OPENAI_GRADING_MODEL=gpt-4o-mini
# GEMINI_GRADING_MODEL=gemini-2.5-flash
# ANTHROPIC_GRADING_MODEL=claude-sonnet-4-6

# OPENAI_VISION_MODEL=gpt-4o-2024-11-20
# GEMINI_VISION_MODEL=gemini-2.5-flash
# ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-20241022


# ── Optional: override default paths ─────────────────────────────────────────
# AUTO_GRADER_RUBRIC_DIR=./data/library/rubrics


# ── Optional: Flask server settings ──────────────────────────────────────────
# FLASK_HOST=127.0.0.1
# FLASK_PORT=5000
# FLASK_DEBUG=0
